-- ==================== LOGIC & FEATURES ====================
local enemiesFolder = nil

local function findEnemiesFolder()
	local found = nil
	local alives = Workspace:FindFirstChild("Alives")
	if alives then found = alives:FindFirstChild("Enemies") end
	if not found then
		for _, v in ipairs(Workspace:GetDescendants()) do
			if v:IsA("Folder") and v.Name == "Enemies" and v.Parent and v.Parent.Name == "Alives" then
				found = v
				break
			end
		end
	end
	return found
end

task.spawn(function()
	while true do
		enemiesFolder = findEnemiesFolder()
		task.wait(1)
	end
end)

local function getHumanoid(obj)
	local m = obj
	if obj:IsA("BasePart") then m = obj.Parent end
	if m and (m:IsA("Model") or m:IsA("Folder")) then
		return m:FindFirstChildWhichIsA("Humanoid")
	end
end

local hlts = {}
local playerHlts = {}
local espOn = false
local autoOn = false
local frozen = false
local autoChestOn = false
local infiniteJumpOn = false
local speedOn = false
local customWalkSpeed = 16

-- Scanning menyeluruh agar tidak ada mob yang lolos
local function getAllMobs()
	local list = {}
	if enemiesFolder then
		for _, v in ipairs(enemiesFolder:GetChildren()) do
			local hh = getHumanoid(v)
			if hh and hh.Health > 0 then
				table.insert(list, {Model = v, Humanoid = hh})
			end
		end
	end
	for _, desc in ipairs(Workspace:GetDescendants()) do
		if desc:IsA("Model") or desc:IsA("Folder") then
			local hh = desc:FindFirstChildWhichIsA("Humanoid")
			if hh and hh.Health > 0 and desc ~= Player.Character then
				local alreadyAdded = false
				for _, item in ipairs(list) do
					if item.Model == desc then alreadyAdded = true break end
				end
				if not alreadyAdded then
					table.insert(list, {Model = desc, Humanoid = hh})
				end
			end
		end
	end
	return list
end

local function updateESP()
	local mobs = getAllMobs()
	for _, d in ipairs(mobs) do
		if espOn and not hlts[d.Model] then
			local hl = Instance.new("Highlight", d.Model)
			hl.FillColor = Color3.fromRGB(180, 180, 180)
			hl.OutlineColor = Color3.new(1, 1, 1)
			hl.FillTransparency = 0.5
			hlts[d.Model] = hl
		elseif not espOn and hlts[d.Model] then
			hlts[d.Model]:Destroy()
			hlts[d.Model] = nil
		end
	end

	for m, hl in pairs(hlts) do
		local alive = false
		for _, d in ipairs(mobs) do if d.Model == m then alive = true break end end
		if not alive then hl:Destroy() hlts[m] = nil end
	end

	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= Player and otherPlayer.Character then
			local char = otherPlayer.Character
			if espOn and not playerHlts[char] then
				local hl = Instance.new("Highlight", char)
				hl.FillColor = Color3.fromRGB(0, 255, 0)
				hl.OutlineColor = Color3.new(1, 1, 1)
				hl.FillTransparency = 0.5
				playerHlts[char] = hl
			elseif not espOn and playerHlts[char] then
				playerHlts[char]:Destroy()
				playerHlts[char] = nil
			end
		end
	end
end

-- Fix 1: Instant Kill dengan sinkronisasi server (Quest & EXP tercatat sempurna tanpa bug visual)
local function killEn(d)
	if not d.Humanoid or d.Humanoid.Health <= 0 then return end
	pcall(function()
		local hh = d.Humanoid
		hh.MaxHealth = 100
		hh.Health = 0 -- Memicu sistem game mendeteksi kematian secara natural
		
		-- Sentuh bagian tubuh agar sistem reward/quest menerima sinyal kill dari player
		if d.Model and d.Model:IsA("Model") then
			local root = d.Model:FindFirstChild("HumanoidRootPart") or d.Model:FindFirstChildWhichIsA("BasePart")
			if root and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
				firetouchinterest(Player.Character.HumanoidRootPart, root, 0)
				firetouchinterest(Player.Character.HumanoidRootPart, root, 1)
			end
		end
	end)
end

local function killAll()
	for _, d in ipairs(getAllMobs()) do
		killEn(d)
	end
end

-- Fix 3: Freeze Mob Total
local function freezeAll()
	pcall(function()
		for _, d in ipairs(getAllMobs()) do
			local hh = d.Humanoid
			if hh and hh.Health > 0 then
				hh.WalkSpeed = frozen and 0 or 16
				hh.JumpPower = frozen and 0 or 50
				for _, st in ipairs({
					Enum.HumanoidStateType.Running, Enum.HumanoidStateType.Jumping, Enum.HumanoidStateType.Falling,
					Enum.HumanoidStateType.Climbing, Enum.HumanoidStateType.Swimming, Enum.HumanoidStateType.Freefall
				}) do
					hh:SetStateEnabled(st, not frozen)
				end
				if d.Model:IsA("Model") then
					for _, part in ipairs(d.Model:GetDescendants()) do
						if part:IsA("BasePart") then
							part.Anchored = frozen
						end
					end
				end
			end
		end
	end)
end

-- Fix 2: Global Auto Chest (Jangkauan Tanpa Batas / Jauh Sekali)
local function processChests()
	if not autoChestOn then return end
	pcall(function()
		local char = Player.Character
		local hrp = char and char:FindFirstChild("HumanoidRootPart")
		if not hrp then return end

		for _, obj in ipairs(Workspace:GetDescendants()) do
			if obj:IsA("ProximityPrompt") then
				obj.MaxActivationDistance = 999999
				obj.HoldDuration = 0
				local parentPart = obj.Parent
				if parentPart and parentPart:IsA("BasePart") then
					local dist = (hrp.Position - parentPart.Position).Magnitude
					-- Jika chest berada di ruangan lain/jauh, teleport mikro instan agar terbuka sempurna
					if dist > 5 and dist < 1500 then
						local oldPos = hrp.CFrame
						hrp.CFrame = parentPart.CFrame + Vector3.new(0, 3, 0)
						task.wait(0.04)
						if fireproximityprompt then
							fireproximityprompt(obj)
						end
						task.wait(0.04)
						hrp.CFrame = oldPos
						break
					else
						if fireproximityprompt then
							fireproximityprompt(obj)
						end
					end
				else
					if fireproximityprompt then
						fireproximityprompt(obj)
					end
				end
			end
		end
	end)
end

